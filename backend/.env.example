# Copy to backend/.env — use top section for local, bottom section for production server.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hpms_core
DATABASE_SSL=false

JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
# JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
# JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_EXPIRES_IN=1h

MFA_ISSUER=HC Solutions Payroll
MFA_REQUIRED=false

ENCRYPTION_MASTER_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

SMS_ENABLED=false
SMS_PROVIDER=africastalking
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=

# --------------------------------------
# Environment
# --------------------------------------
NODE_ENV=production
PORT=3000

# --------------------------------------
# PostgreSQL Database Connection
# --------------------------------------
DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@database:5432/hpms
DATABASE_SSL=false

# --------------------------------------
# Authentication & Security
# --------------------------------------
# Generate new secrets for production! Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_HEX_STRING
ENCRYPTION_MASTER_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# MFA issuer (shown in Google Authenticator)
MFA_ISSUER=HC Solutions Payroll

# Enable MFA (Multi-Factor Authentication)
MFA_REQUIRED=true

# --------------------------------------
# CORS Settings
# --------------------------------------
# Production (payroll.hcsolutions-rw.com) — use these when deploying:
CORS_ORIGINS=https://payroll.hcsolutions-rw.com

# --------------------------------------
# App URL (for emails, login/approval links)
# --------------------------------------
APP_URL=https://payroll.hcsolutions-rw.com

# --------------------------------------
# Email / SMTP Configuration
# --------------------------------------
# For Gmail: Use app-specific password (not your regular password)
# For other providers: Use your SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=HC Solutions Payroll

# --------------------------------------
# Logging
# --------------------------------------
LOG_LEVEL=info
