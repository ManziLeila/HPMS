##########################
# Backend (.env at root)
##########################

# Node environment: development | test | production
NODE_ENV=development

# API port
PORT=4000

# Postgres connection URL (user:pass@host:port/db)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hpms_core

# Use SSL for database connection (true/false)
DATABASE_SSL=false

# JWT configuration (choose ONE of: secret OR key pair)
# For local/dev it's easiest to use JWT_SECRET.
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
# JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
# JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_EXPIRES_IN=1h

# MFA / Auth
MFA_ISSUER=HC Solutions Payroll
MFA_REQUIRED=false

# Encryption key (32+ chars, keep secret!)
ENCRYPTION_MASTER_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Logging level: error | warn | info | debug | trace
LOG_LEVEL=info

# Comma-separated list of frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# SMS configuration (optional)
SMS_ENABLED=false
SMS_PROVIDER=africastalking
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=

##########################
# Frontend (Vite)
##########################

# Example API base override (optional)
# VITE_API_BASE_URL=http://localhost:4000/api
