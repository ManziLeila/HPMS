##########################
# LOCAL DEVELOPMENT (default)
# Use this when running on your PC. On the server use backend/.env with production values.
##########################
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hpms_core
DATABASE_SSL=false

JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
# JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
# JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_EXPIRES_IN=1h
MFA_ISSUER=HC Solutions Payroll
MFA_REQUIRED=false
ENCRYPTION_MASTER_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
LOG_LEVEL=info

# CORS & App URL — local: frontend on 5173, backend on 4000
CORS_ORIGINS=http://localhost:5173
APP_URL=

SMS_ENABLED=false
SMS_PROVIDER=africastalking
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=

##########################
# PRODUCTION (payroll.hcsolutions-rw.com)
# On the server: copy backend/.env.example to backend/.env and set:
#   NODE_ENV=production
#   CORS_ORIGINS=https://payroll.hcsolutions-rw.com
#   APP_URL=https://payroll.hcsolutions-rw.com
#   (plus DATABASE_URL, JWT_SECRET, ENCRYPTION_MASTER_KEY, SMTP, etc.)
# Frontend: do NOT set VITE_API_BASE_URL — app will use same origin /api.
##########################
